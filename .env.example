# Copy to .env.local in your shell or IDE — never commit real values.

# App under test (Playwright base URL)
# DEEPSIGHT_BASE_URL=http://localhost:8080

# Project path for dashboard / verify scripts
# DEEPSIGHT_PROJECT_PATH=/path/to/your/app

# Option B only — external LLM (skip = Option A, IDE-powered)
# DEEPSIGHT_LLM_PROVIDER=openai
# DEEPSIGHT_LLM_API_KEY=
# DEEPSIGHT_LLM_MODEL=gpt-4o-mini
# DEEPSIGHT_LLM_BASE_URL=          # Ollama: http://localhost:11434
