# Target project for web dashboard / dev scripts (required for server.mjs, start-web.mjs)
DEEPSIGHT_PROJECT_PATH=

# Optional: GateMCP CLI dist path (auto-detected via npm root -g if unset)
GATEMCP_DIR=

# Optional: LLM auto-generation (Option B in README)
DEEPSIGHT_LLM_PROVIDER=
DEEPSIGHT_LLM_API_KEY=
DEEPSIGHT_LLM_BASE_URL=
DEEPSIGHT_LLM_MODEL=
