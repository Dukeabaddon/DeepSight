{
  "name": "@deepsight/deepsight-mcp",
  "version": "0.1.0",
  "description": "DeepSight - Open source AI-powered testing MCP server. Automatically generates, executes, and debugs tests for your project.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "deepsight": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "web": "node start-web.mjs",
    "test:analyze": "npm run build && node scripts/test-testid-parse.mjs && node scripts/verify-deep-analysis.mjs",
    "test:run:live": "npm run build && node scripts/verify-real-run.mjs",
    "test:live:e2e": "npm run build && node scripts/verify-live-e2e.mjs",
    "test:analyze:unit": "npm run build && node scripts/test-next-routes.mjs && node scripts/test-function-count.mjs",
    "security:check": "node scripts/security-check.mjs",
    "prepublishOnly": "npm run build && npm run security:check"
  },
  "keywords": [
    "testing",
    "automation",
    "ai",
    "mcp",
    "cursor",
    "vscode",
    "playwright",
    "deepsight"
  ],
  "author": "Dukeabaddon (https://github.com/Dukeabaddon)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dukeabaddon/DeepSight.git"
  },
  "bugs": {
    "url": "https://github.com/Dukeabaddon/DeepSight/issues"
  },
  "homepage": "https://github.com/Dukeabaddon/DeepSight#readme",
  "files": [
    "dist",
    "assets"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "express": "^5.1.0",
    "fs-extra": "^11.3.0",
    "open": "^11.0.0",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.28.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.30",
    "zod-to-json-schema": "^3.25.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2"
  },
  "optionalDependencies": {
    "playwright": "^1.52.0",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/express": "^5.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "playwright": "^1.52.0",
    "typescript": "^5.8.0"
  }
}
