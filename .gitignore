# --- Dependencies ---
node_modules/

# --- Build output (run `npm run build` after clone; CI builds before publish) ---
dist/
*.tsbuildinfo

# --- GateMCP local runtime cache (NOT source — integration code is gatemcp-integration.mjs) ---
.gate-mcp/

# --- Secrets & local env ---
.env
.env.*
!.env.example

# --- Generated when DeepSight runs on a *target* project (never commit from consumer repos) ---
deepsight_tests/
.deepsight/
# legacy third-party artifact folder name (if present in target projects)
.legacy-mcp-cache/

# --- Test / Playwright artifacts ---
test-results/
playwright-report/
blob-report/
playwright/.cache/
coverage/
*.log

# --- OS / IDE ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# --- Optional local scratch ---
scratch/
tmp/
